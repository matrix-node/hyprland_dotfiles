# Sensitive / generated
*.zwc
*.zst
__pycache__/
*.pyc
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Large media that should not ship by accident
*.mp4
*.webm
*.mkv
*.mov

# Neovim plugin manager cache / lock (regenerated on first run)
config/nvim/.cache/
config/nvim/lazy-lock.json

# Installer runtime logs
.install-logs/
*.log

# Backup artifacts from installer
*.bak
*.bak.*
